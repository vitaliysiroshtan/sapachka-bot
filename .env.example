# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Comma-separated list of allowed group chat IDs (leave empty to allow all)
# Example: ALLOWED_CHATS=-1001234567890,-1009876543210
ALLOWED_CHATS=

# Your personal Telegram user ID — enables /say <chat_id> <message> from private chat
# Send /chatid to the bot in a private chat to find your ID
ADMIN_USER_ID=
